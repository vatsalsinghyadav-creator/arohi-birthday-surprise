<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>A Surprise for Arohi</title>

<style>

body{
margin:0;
font-family: 'Segoe UI', sans-serif;
overflow:hidden;
background:black;
color:white;
}

.page{
position:absolute;
height:100vh;
width:100%;
display:flex;
justify-content:center;
align-items:center;
flex-direction:column;
text-align:center;
opacity:0;
pointer-events:none;
transition:opacity 0.8s;
}

.page.active{
opacity:1;
pointer-events:auto;
}

#page1{background:black;}
#pageNo{background:black;}
#page2{background:#ffb6c1;}
#page3{background:#ffc0cb;}

button{
padding:12px 26px;
font-size:18px;
border:none;
border-radius:12px;
margin:10px;
cursor:pointer;
background:white;
color:#ff3d6e;
font-weight:bold;
}

.poster{
width:330px;
border-radius:16px;
box-shadow:0 0 25px rgba(0,0,0,0.3);
}

.cake{
width:210px;
cursor:pointer;
transition:transform .3s;
}

.cake:hover{
transform:scale(1.08);
}

.heart{
position:absolute;
font-size:18px;
animation:float 7s linear infinite;
opacity:0.7;
}

@keyframes float{
0%{transform:translateY(100vh) scale(.8);}
100%{transform:translateY(-10vh) scale(1.2);}
}

.balloon{
position:absolute;
font-size:34px;
animation:fall 6s linear forwards;
}

@keyframes fall{
0%{transform:translateY(-10vh);}
100%{transform:translateY(110vh);}
}

.confetti{
position:absolute;
width:8px;
height:8px;
background:red;
animation:confettiFall 4s linear forwards;
}

@keyframes confettiFall{
0%{transform:translateY(-10vh) rotate(0deg);}
100%{transform:translateY(110vh) rotate(720deg);}
}

#finalMessage{
font-size:32px;
margin-top:25px;
color:#ff2e63;
font-weight:bold;
text-shadow:0 0 15px white;
}

</style>
</head>

<body>

<audio id="music" src="music.mp3"></audio>

<div id="page1" class="page active">
<h1>Are you ready, Arohi?</h1>
<div>
<button onclick="goPage2()">Yes</button>
<button onclick="goNo()">No</button>
</div>
</div>

<div id="pageNo" class="page">
<h2>No… you have to be ready for the surprise.</h2>
<button onclick="goPage1()">Go back</button>
</div>

<div id="page2" class="page">
<img src="poster.jpg" class="poster">
<h2>Are you ready to cut the cake, my love?</h2>
<button onclick="goPage3()">Cut the Cake 🎂</button>
</div>

<div id="page3" class="page">
<img src="cake.png" class="cake" onclick="cutCake()">
<h2 id="finalMessage"></h2>
</div>

<script>

function showPage(id){
document.querySelectorAll(".page").forEach(p=>p.classList.remove("active"));
document.getElementById(id).classList.add("active");
}

function goPage1(){ showPage("page1"); }

function goNo(){ showPage("pageNo"); }

function goPage2(){
showPage("page2");
document.getElementById("music").play();
}

function goPage3(){ showPage("page3"); }

function cutCake(){

createBalloons();
createConfetti();
typeMessage();

}

function typeMessage(){

let text="Happy Birthday Arohi ❤️ Forever yours, Vatsal";
let i=0;

let interval=setInterval(()=>{
document.getElementById("finalMessage").innerHTML+=text[i];
i++;
if(i>=text.length) clearInterval(interval);
},70);

}

function createHearts(){

setInterval(()=>{
let heart=document.createElement("div");
heart.className="heart";
heart.style.left=Math.random()*100+"vw";
heart.innerHTML="❤️";
document.body.appendChild(heart);
},400);

}

function createBalloons(){

for(let i=0;i<30;i++){
let b=document.createElement("div");
b.className="balloon";
b.style.left=Math.random()*100+"vw";
b.innerHTML="🎈";
document.body.appendChild(b);
}

}

function createConfetti(){

for(let i=0;i<80;i++){

let c=document.createElement("div");
c.className="confetti";

c.style.left=Math.random()*100+"vw";
c.style.background=["#ff2e63","#ffd166","#06d6a0","#118ab2"][Math.floor(Math.random()*4)];

document.body.appendChild(c);

}

}

createHearts();

</script>

</body>
</html>
