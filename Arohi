
body{
background:black;
color:white;
font-family:Arial;
display:flex;
justify-content:center;
align-items:center;
height:100vh;
text-align:center;
}

h1{
font-size:40px;
margin-bottom:30px;
}

.buttons{
display:flex;
gap:20px;
justify-content:center;
}

button{
padding:12px 30px;
font-size:18px;
border:none;
border-radius:8px;
cursor:pointer;
}

.yes{
background:#ff4d6d;
color:white;
}

.no{
background:gray;
color:white;
}

button:hover{
transform:scale(1.1);
transition:0.2s;
}
